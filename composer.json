{
  "name": "yuriytaranov/waest",
  "description": "WhatsApp Encryption Stream",
  "type": "library",
  "require": {
    "php": ">=8.1",
    "psr/http-message": "^2.0",
    "psr/http-factory": "^1.1",
    "ext-openssl": "*",
    "ext-ctype": "*"
  },
  "autoload": {
    "psr-4": {
      "Waest\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Waest\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "*",
    "guzzlehttp/psr7": "^2.9",
    "mockery/mockery": "^1.6"
  }
}
